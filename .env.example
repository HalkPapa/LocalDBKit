# ============================================
# LocalDBKit Environment Variables
# ============================================
# ⚠️  SECURITY WARNING / セキュリティ警告
# ============================================
# 1. Copy this file to create .env:
#    cp .env.example .env
#
# 2. CHANGE ALL PASSWORDS before production use!
#    本番環境では必ず全てのパスワードを変更してください！
#
# 3. Generate strong passwords:
#    openssl rand -base64 32
#    または
#    python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 4. Never commit .env file to Git!
#    .envファイルは絶対にGitにコミットしないでください！
# ============================================

COMPOSE_PROJECT_NAME=local_databases

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=mydb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MongoDB
MONGO_USERNAME=admin
MONGO_PASSWORD=your_password_here
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your_password_here
MONGO_INITDB_DATABASE=mydb
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=mydb

# Mongo Express (MongoDB UI)
ME_CONFIG_MONGODB_ADMINUSERNAME=admin
ME_CONFIG_MONGODB_ADMINPASSWORD=your_password_here
ME_CONFIG_MONGODB_URL=mongodb://admin:your_password_here@mongodb:27017/

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Open WebUI
WEBUI_SECRET_KEY=your-secret-key-change-in-production

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your_password_here

# API Gateway
JWT_SECRET_KEY=your-secret-key-change-in-production-please-use-a-strong-random-key-at-least-32-characters

# Connection Strings
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/mydb
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://admin:your_password_here@localhost:27017/mydb?authSource=admin
QDRANT_URL=http://localhost:6333
