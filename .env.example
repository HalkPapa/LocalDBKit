COMPOSE_PROJECT_NAME=local_databases

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=mydb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MongoDB
MONGO_USERNAME=admin
MONGO_PASSWORD=your_password_here
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=mydb

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# API Gateway
JWT_SECRET_KEY=your-secret-key-change-in-production-please-use-a-strong-random-key-at-least-32-characters

# Connection Strings
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/mydb
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://admin:your_password_here@localhost:27017/mydb?authSource=admin
QDRANT_URL=http://localhost:6333
