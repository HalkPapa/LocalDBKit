# API Gateway Configuration

# Application
APP_NAME="LocalDBKit API Gateway"
APP_VERSION="0.3.0"
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Security (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=your-secret-key-change-in-production-please-use-a-strong-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_LLM=10/minute

# Backend Services
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/mydb
MONGODB_URL=mongodb://admin:admin@mongodb:27017
REDIS_URL=redis://redis:6379
OLLAMA_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333

# Logging
LOG_LEVEL=INFO
